{#
/**
 * @file
 * Theme override for Listing Grid Section paragraph.
 */
#}
{%
  set classes = [
    'paragraph',
    'paragraph--type--listing-grid-section',
    'listing-grid-section',
    'py-5',
  ]
%}

{% set heading = paragraph.field_heading.value ?? '' %}

<section{{ attributes.addClass(classes) }}>
  <div class="container container-xl">
    {% if heading %}
      <h2 class="listing-grid-section__heading text-center mb-3">{{ heading }}</h2>
    {% endif %}

    <div class="listing-grid-section__grid mt-5">
      {{ content.field_listing_item }}
    </div>
  </div>
</section>
