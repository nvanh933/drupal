{#
/**
 * @file
 * Theme override to display a single Drupal page while offline.
 *
 * All available variables are mirrored in page.html.twig.
 * Some may be blank but they are provided for consistency.
 *
 * @see \Drupal\Core\Theme\ThemePreprocess::preprocessMaintenancePage()
 */
#}
<div class="layout-container container py-5">
  <div class="row justify-content-center">
    <div class="col-12 col-lg-10 col-xl-8">
      <div class="card border-0 shadow-sm">
        <div class="card-body p-4 p-md-5">
          <header role="banner" class="text-center mb-4">
            {% if logo %}
              <a href="{{ front_page }}" title="{{ 'Home'|t }}" rel="home" class="d-inline-block mb-3">
                <img src="{{ logo }}" alt="{{ 'Home'|t }}" class="img-fluid"/>
              </a>
            {% endif %}

            {% if site_name or site_slogan %}
              <div class="name-and-slogan">
                {% if site_name %}
                 <h1 class="site-name h3 mb-2">
                   <a href="{{ front_page }}" title="{{ 'Home'|t }}" rel="home" class="text-decoration-none">{{ site_name }}</a>
                 </h1>
                {% endif %}

                {% if site_slogan %}
                  <div class="site-slogan text-muted">{{ site_slogan }}</div>
                {% endif %}
              </div>
            {% endif %}
          </header>

          <main role="main">
            {% if title %}
              <h2 class="h4 mb-3">{{ title }}</h2>
            {% endif %}

            <div class="mb-3">{{ page.highlighted }}</div>

            {{ page.content }}
          </main>

          {% if page.sidebar_first or page.sidebar_second %}
            <div class="row g-4 mt-1">
              {% if page.sidebar_first %}
                <aside class="layout-sidebar-first col-12 col-lg-6" role="complementary">
                  {{ page.sidebar_first }}
                </aside>
              {% endif %}

              {% if page.sidebar_second %}
                <aside class="layout-sidebar-second col-12 col-lg-6" role="complementary">
                  {{ page.sidebar_second }}
                </aside>
              {% endif %}
            </div>
          {% endif %}

          {% if page.footer %}
            <footer role="contentinfo" class="mt-4 pt-3 border-top">
              {{ page.footer }}
            </footer>
          {% endif %}
        </div>
      </div>
    </div>
  </div>
</div>
