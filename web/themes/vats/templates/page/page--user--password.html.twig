<div class="vats-user-password-page container-fluid p-0">
  <div class="vats-user-password-page__layout row g-0 min-vh-100">
    <div class="vats-user-password-page__visual col-lg-7 d-none d-lg-block position-relative">
      <img
        src="{{ base_path ~ directory }}/images/login/background.jpg"
        alt="{{ site_name }}"
        class="vats-user-password-page__bg-image"
      />
      <div class="vats-user-password-page__visual-content position-absolute bottom-0 start-0 end-0 text-white">
        <h1 class="display-6 fw-semibold mb-3">{{ site_name }}</h1>
        <p class="mb-0 fs-5">{{ site_slogan }}</p>
      </div>
    </div>

    <div class="vats-user-password-page__panel col-12 col-lg-5 d-flex align-items-center justify-content-center p-4 p-md-5">
      <div class="vats-user-password-page__card card border-0 shadow-sm w-100">
        <div class="card-body p-4 p-md-5">
          <div class="vats-user-password-page__top-actions mb-3">
            <a href="{{ front_page }}" class="btn btn-link text-decoration-none px-0">
              <i class="bi bi-arrow-left me-1" aria-hidden="true"></i>{{ 'Quay lại trang chủ'|t }}
            </a>
          </div>

          <div class="vats-user-password-page__header text-center mb-4">
            <a href="{{ front_page }}" class="d-inline-flex align-items-center justify-content-center mb-3" title="{{ 'Trang chủ'|t }}">
              <img src="{{ base_path ~ directory }}/images/logo.svg" alt="{{ site_name }}" class="vats-user-password-page__logo" />
            </a>
            <h2 class="h4 mb-2">{{ 'Đặt lại mật khẩu'|t }}</h2>
            <p class="text-muted mb-0">{{ 'Nhập email để nhận hướng dẫn đặt lại mật khẩu.'|t }}</p>
          </div>

          <div class="vats-user-password-page__form">
            {{ page.content }}
          </div>

          <div class="vats-user-password-page__actions mt-4 pt-3 border-top text-center">
            <a href="{{ path('user.login') }}" class="btn btn-link text-decoration-none">
              {{ 'Đăng nhập'|t }}
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
