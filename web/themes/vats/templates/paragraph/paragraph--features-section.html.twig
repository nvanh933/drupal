{#
/**
 * @file
 * Theme override for Features Section paragraph.
 */
#}
{%
  set classes = [
    'paragraph',
    'paragraph--type--features-section',
    'features-section',
    'py-5',
  ]
%}

{% set heading = paragraph.field_heading.value ?? '' %}

<section{{ attributes.addClass(classes) }}>
  <div class="container container-xl">
    {% if heading %}
      <h2 class="features-section__heading text-center mb-5">{{ heading }}</h2>
    {% endif %}

    <div class="features-section__grid">
      {{ content.field_features }}
    </div>
  </div>
</section>
