{#
/**
 * @file
 * Theme override for CTA Section paragraph.
 */
#}
{%
  set classes = [
    'paragraph',
    'paragraph--type--cta-section',
    'cta-section',
    'py-5',
  ]
%}

{% set heading = paragraph.field_heading.value ?? '' %}
{% set subheading = paragraph.field_subheading.value ?? '' %}
{% set btn_text = paragraph.field_primary_button_text.value ?? '' %}
{% set btn_url = paragraph.field_primary_button_link.0.url ?? null %}

<section{{ attributes.addClass(classes) }}>
  <div class="container container-xl text-center">
    {% if heading %}
      <h2 class="cta-section__title mb-4">{{ heading }}</h2>
    {% endif %}

    {% if subheading %}
      <p class="cta-section__subtitle mx-auto mb-5">{{ subheading }}</p>
    {% endif %}

    {% if btn_url and btn_text %}
      <div class="cta-section__actions d-flex flex-wrap justify-content-center gap-3">
        <a href="{{ btn_url }}" class="cta-section__btn btn btn-outline-light btn-lg px-4">
          {{ btn_text }}
        </a>
      </div>
    {% endif %}
  </div>
</section>
