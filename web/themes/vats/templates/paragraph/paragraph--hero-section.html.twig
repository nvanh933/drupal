{#
/**
 * @file
 * Theme override for Hero Section paragraph.
 */
#}
{%
  set classes = [
    'paragraph',
    'paragraph--type--hero-section',
    'hero-section',
  ]
%}

{% set primary_url = paragraph.field_primary_button_link.0.url ?? null %}
{% set primary_text = paragraph.field_primary_button_text.value ?? '' %}
{% set secondary_url = paragraph.field_secondary_button_link.0.url ?? null %}
{% set secondary_text = paragraph.field_secondary_button_text.value ?? '' %}
{% set heading = paragraph.field_heading.value ?? '' %}
{% set subheading = paragraph.field_subheading.value ?? '' %}

<section{{ attributes.addClass(classes) }}>
  <div class="container container-xl">
    <div class="row align-items-center g-4 g-lg-5">
      <div class="col-12 col-lg-6">
        <div class="hero-section__content pe-lg-4">
          {% if heading %}
            <h1 class="hero-section__heading display-4 fw-bold mb-3">{{ heading }}</h1>
          {% endif %}

          {% if subheading %}
            <p class="hero-section__subheading fs-2 lh-sm mb-2">{{ subheading }}</p>
          {% endif %}

          <div class="hero-section__actions d-flex flex-wrap align-items-center gap-3">
            {% if primary_url and primary_text %}
              <a href="{{ primary_url }}" class="hero-section__primary-btn btn btn-primary btn-lg px-4 rounded-pill">
                {{ primary_text }}
              </a>
            {% endif %}

            {% if secondary_url and secondary_text %}
              <a href="{{ secondary_url }}" class="hero-section__secondary-btn btn btn-secondary btn-lg px-4 rounded-pill">
                {{ secondary_text }}
              </a>
            {% endif %}
          </div>
        </div>
      </div>

      <div class="col-12 col-lg-6 text-center">
        <div class="hero-section__media">
          {{ content.field_image }}
        </div>
      </div>
    </div>
  </div>
</section>
